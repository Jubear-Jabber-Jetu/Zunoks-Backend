{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "UseHttpsRedirection": false,
  "Cors": {
    "AllowAnyOrigin": true,
    "AllowedOrigins": [
      "https://zunoks-user.vercel.app",
      "https://zunoks-admin.vercel.app",
      "https://fund.myrecombd.com",
      "https://your-recom-admin-domain.com"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_SERVER;Database=ZunoksDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=true;Trust Server Certificate=True"
  },
  "Jwt": {
    "Key": "CHANGE-ME-min-32-characters-secret-key",
    "Issuer": "ZunoksBackend",
    "Audience": "ReComAdmin",
    "ExpiryMinutes": 480
  },
  "ReComAdmin": {
    "Email": "admin@myrecombd.com",
    "Password": "CHANGE-ME-strong-password"
  }
}
